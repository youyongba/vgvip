            </thead>
            <tbody>
                <tr><td>Telegram专属群</td><td><span class="tag-vip">✓ 可加入</span></td><td><span class="tag-normal">× 无权限</span></td></tr>
                <tr><td>行情策略分析</td><td><span class="tag-vip">✓ 每日更新</span></td><td><span class="tag-normal">× 仅公开内容</span></td></tr>
                <tr><td>独家学习资源</td><td><span class="tag-vip">✓ 免费下载</span></td><td><span class="tag-normal">× 付费购买</span></td></tr>
                <tr><td>一对一答疑</td><td><span class="tag-vip">✓ 24小时内回复</span></td><td><span class="tag-normal">× 无</span></td></tr>
                <tr><td>到期自动提醒</td><td><span class="tag-vip">✓ 自动私信</span></td><td><span class="tag-normal">× 无</span></td></tr>
                <tr><td>资产安全指南</td><td><span class="tag-vip">✓ 专属定制</span></td><td><span class="tag-normal">× 基础内容</span></td></tr>
            </tbody>
        </table>
    </div>

    <div class="benefits-cta">
        <a href="/vip" class="cta-btn">立即订阅VIP会员</a>
    </div>
</section>

<%- include('../partials/footer') %>
</body>
</html>
