    </div>

    <div class="benefits-cards">
        <div class="benefit-card">
            <div class="card-icon"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/telegram.svg" alt="专属社群"></div>
            <h3 class="card-title">Telegram VIP专属群</h3>
