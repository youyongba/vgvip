<%
const pageStyles = `
.benefits-section { max-width: 1200px; margin: 4rem auto; padding: 0 5%; }
.benefits-header { text-align: center; margin-bottom: 4rem; }
.benefits-title { font-size: 2.5rem; line-height: 1.3; margin-bottom: 1rem; background: linear-gradient(135deg, #3c82f6, #8338ec); -webkit-background-clip: text; background-clip: text; color: transparent; }
.benefits-subtitle { color: #b0b0c0; font-size: 1.1rem; max-width: 800px; margin: 0 auto; }
.benefits-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; }
.benefit-card { background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 2rem; border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); transition: transform 0.3s, border-color 0.3s; }
.benefit-card:hover { transform: translateY(-5px); border-color: rgba(60, 130, 246, 0.3); }
.benefit-card .card-icon { width: 60px; height: 60px; background: linear-gradient(135deg, rgba(60, 130, 246, 0.2), rgba(131, 56, 236, 0.2)); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; }
.benefit-card .card-icon img { width: 32px; height: 32px; object-fit: contain; }
.benefit-card .card-title { font-size: 1.3rem; font-weight: 600; margin-bottom: 1rem; color: #fff; }
.benefit-card .card-desc { color: #b0b0c0; line-height: 1.6; font-size: 1rem; }
.benefits-compare { margin-top: 6rem; background: rgba(255, 255, 255, 0.03); border-radius: 16px; padding: 2.5rem; border: 1px solid rgba(255, 255, 255, 0.1); }
.compare-title { font-size: 1.8rem; margin-bottom: 2rem; text-align: center; }
.compare-table { width: 100%; border-collapse: collapse; }
.compare-table th, .compare-table td { padding: 1.2rem; text-align: left; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
.compare-table th { color: #e0e0e0; font-weight: 600; }
.compare-table td { color: #b0b0c0; }
.compare-table tr:last-child td { border-bottom: none; }
.tag-vip { color: #3c82f6; font-weight: 600; }
.tag-normal { color: #888; }
.benefits-cta { text-align: center; margin-top: 4rem; }
.cta-btn { display: inline-block; background: linear-gradient(135deg, #3c82f6, #8338ec); border-radius: 8px; padding: 1.2rem 2.5rem; color: #fff; font-size: 1.1rem; font-weight: 600; text-decoration: none; transition: opacity 0.3s; }
.cta-btn:hover { opacity: 0.9; }
.footer { margin-top: 6rem; }
@media (max-width: 768px) { .benefits-title { font-size: 2rem; } .benefits-cards { grid-template-columns: 1fr; } .compare-table th, .compare-table td { padding: 0.8rem; font-size: 0.9rem; } .cta-btn { width: 100%; } }
`;
%>
<%- include('../partials/head', { title: '社群权益', pageStyles }) %>
<%- include('../partials/header', { activeNav: 'benefits' }) %>

