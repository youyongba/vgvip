<%
const pageStyles = `
.contact-section { max-width: 1000px; margin: 4rem auto; padding: 0 5%; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
.contact-info h1 { font-size: 2.5rem; line-height: 1.3; margin-bottom: 1.5rem; background: linear-gradient(135deg, #3c82f6, #8338ec); -webkit-background-clip: text; background-clip: text; color: transparent; }
.contact-info p { color: #b0b0c0; font-size: 1.1rem; line-height: 1.6; margin-bottom: 3rem; }
.contact-methods { display: flex; flex-direction: column; gap: 1.5rem; }
.method-card { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; padding: 1.5rem; display: flex; align-items: center; gap: 1.5rem; transition: transform 0.3s, border-color 0.3s; text-decoration: none; color: inherit; }
.method-card:hover { transform: translateX(5px); border-color: rgba(60, 130, 246, 0.3); background: rgba(255, 255, 255, 0.08); }
.method-icon { width: 48px; height: 48px; background: rgba(60, 130, 246, 0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #3c82f6; font-size: 1.5rem; }
.method-details h3 { font-size: 1.1rem; margin-bottom: 0.3rem; color: #fff; }
.method-details span { color: #b0b0c0; font-size: 0.9rem; }
.contact-form-container { background: rgba(255, 255, 255, 0.05); border-radius: 16px; padding: 2.5rem; border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); }
.form-title { font-size: 1.5rem; margin-bottom: 2rem; color: #fff; }
.form-group { margin-bottom: 1.5rem; }
.form-label { display: block; color: #b0b0c0; margin-bottom: 0.5rem; font-size: 0.9rem; }
.form-input, .form-textarea { width: 100%; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px; padding: 1rem; color: #fff; outline: none; font-size: 1rem; transition: border-color 0.3s; }
.form-input:focus, .form-textarea:focus { border-color: #3c82f6; }
.form-textarea { resize: vertical; min-height: 120px; }
.submit-btn { width: 100%; background: linear-gradient(135deg, #3c82f6, #8338ec); border: none; border-radius: 8px; padding: 1rem; color: #fff; font-size: 1rem; font-weight: 600; cursor: pointer; transition: opacity 0.3s; }
.submit-btn:hover { opacity: 0.9; }
@media (max-width: 900px) { .contact-section { grid-template-columns: 1fr; gap: 3rem; } .contact-info h1 { font-size: 2rem; } }
`;
%>
<%- include('../partials/head', { title: '联系我们', pageStyles }) %>
<%- include('../partials/header', { activeNav: 'contact' }) %>

<section class="contact-section">
    <div class="contact-info">
        <h1>需要帮助？<br>我们随时为您服务</h1>
        <p>无论是关于会员订阅的疑问，还是商务合作意向，或者是对社群的建议，欢迎随时联系我们。我们的团队通常会在 24 小时内回复。</p>
        <div class="contact-methods">
            <a href="https://t.me/your_support_bot" target="_blank" class="method-card">
                <div class="method-icon"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/telegram.svg" width="24" height="24" alt="Telegram"></div>
                <div class="method-details">
                    <h3>Telegram 客服</h3>
                    <span>@Web3VIP_Support (推荐)</span>
                </div>
            </a>
            <a href="mailto:support@web3vip.com" class="method-card">
                <div class="method-icon">✉️</div>
                <div class="method-details">
                    <h3>电子邮件</h3>
                    <span>support@web3vip.com</span>
                </div>
            </a>
            <a href="mailto:business@web3vip.com" class="method-card">
                <div class="method-icon">🤝</div>
                <div class="method-details">
                    <h3>商务合作</h3>
                    <span>business@web3vip.com</span>
                </div>
            </a>
        </div>
    </div>
    <div class="contact-form-container">
        <h2 class="form-title">在线留言</h2>
        <form id="contactForm">
            <div class="form-group">
                <label class="form-label">您的称呼 / Telegram ID</label>
                <input type="text" class="form-input" placeholder="例如：@username" required>
            </div>
            <div class="form-group">
                <label class="form-label">联系邮箱</label>
                <input type="email" class="form-input" placeholder="name@example.com" required>
            </div>
            <div class="form-group">
                <label class="form-label">留言内容</label>
                <textarea class="form-textarea" placeholder="请详细描述您遇到的问题或建议..." required></textarea>
            </div>
            <button type="submit" class="submit-btn">发送留言</button>
        </form>
    </div>
</section>

<%- include('../partials/footer') %>
<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = this.querySelector('.submit-btn');
    const originalText = btn.innerText;
    btn.innerText = '发送中...';
    btn.disabled = true;
    btn.style.opacity = '0.7';
    setTimeout(() => {
        alert('留言已发送！我们会尽快通过 Telegram 或邮件联系您。');
        this.reset();
        btn.innerText = originalText;
        btn.disabled = false;
        btn.style.opacity = '1';
    }, 1500);
});
</script>
</body>
</html>
